# =============================================================================
# SRS (Support Request System) Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
ENV=development
DEBUG=true
APP_NAME=SRS Support System
APP_VERSION=1.0.0
HOST=0.0.0.0
PORT=8000

# -----------------------------------------------------------------------------
# Security Settings
# -----------------------------------------------------------------------------
SECRET_KEY=change-this-secret-key-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# -----------------------------------------------------------------------------
# Email Configuration (for OTP, notifications)
# -----------------------------------------------------------------------------
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=noreply@yourdomain.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=your-resend-api-key

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Development (SQLite - no setup needed)
DATABASE_URL=sqlite:///./support.db

# Production (PostgreSQL via Neon/Supabase/AWS RDS)
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Database Pool Settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30

# -----------------------------------------------------------------------------
# AI/ML Configuration
# -----------------------------------------------------------------------------
AI_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7

# Alternative AI Providers
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your-anthropic-api-key

# -----------------------------------------------------------------------------
# Decision Engine Settings
# -----------------------------------------------------------------------------
CONFIDENCE_THRESHOLD_AUTO_RESOLVE=0.75
CONFIDENCE_THRESHOLD_ESCALATE=0.5
MAX_SIMILAR_TICKETS=5
SIMILARITY_THRESHOLD=0.8

# -----------------------------------------------------------------------------
# Cache Configuration (Redis)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600
CACHE_PREFIX=srs:

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/app.log

# -----------------------------------------------------------------------------
# Monitoring & Metrics
# -----------------------------------------------------------------------------
SENTRY_DSN=
PROMETHEUS_ENABLED=false
METRICS_PORT=9090

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------
WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#support

# -----------------------------------------------------------------------------
# Development Tools
# -----------------------------------------------------------------------------
RELOAD=true
PROFILING_ENABLED=false
